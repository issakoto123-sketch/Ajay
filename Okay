<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Ajay — Portfolio</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:        #F9F8F6;
      --text:      #111111;
      --accent:    #3B5E2B;
      --muted:     #888880;
      --rule:      #DDDCD7;
      --card-bg:   #F2F1EE;
      --display:   'Playfair Display', Georgia, serif;
      --body:      'DM Sans', system-ui, sans-serif;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--body);
      font-size: 16px;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    /* ─── NAV ─────────────────────────────────────────────── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      padding: 1.25rem 2.5rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: rgba(249, 248, 246, 0.92);
      backdrop-filter: blur(8px);
      border-bottom: 1px solid var(--rule);
    }

    .nav-name {
      font-family: var(--display);
      font-size: 1.05rem;
      font-weight: 500;
      letter-spacing: 0.01em;
      color: var(--text);
      text-decoration: none;
    }

    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
    }

    .nav-links a {
      font-size: 0.85rem;
      font-weight: 400;
      color: var(--muted);
      text-decoration: none;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      transition: color 0.2s;
    }

    .nav-links a:hover { color: var(--text); }

    /* ─── HERO ────────────────────────────────────────────── */
    .hero {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 8rem 2.5rem 4rem;
      max-width: 820px;
      margin: 0 auto;
    }

    .hero-eyebrow {
      font-size: 0.8rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent);
      font-weight: 500;
      margin-bottom: 1.4rem;
    }

    .hero-name {
      font-family: var(--display);
      font-size: clamp(3.2rem, 9vw, 6.5rem);
      font-weight: 400;
      line-height: 1.05;
      letter-spacing: -0.02em;
      color: var(--text);
      margin-bottom: 1.6rem;
    }

    /* Cycling identity line */
    .hero-identity {
      font-family: var(--display);
      font-size: clamp(1rem, 2.5vw, 1.35rem);
      font-weight: 400;
      color: var(--muted);
      margin-bottom: 2.4rem;
      min-height: 2em;
    }

    .cycling-word {
      color: var(--accent);
      border-bottom: 1.5px solid var(--accent);
      padding-bottom: 1px;
    }

    .hero-desc {
      font-size: 1rem;
      font-weight: 300;
      color: #555;
      max-width: 500px;
      line-height: 1.75;
      margin-bottom: 2.8rem;
    }

    .hero-cta {
      display: inline-block;
      padding: 0.75rem 1.8rem;
      background: var(--text);
      color: var(--bg);
      text-decoration: none;
      font-size: 0.85rem;
      font-weight: 500;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      transition: background 0.2s, color 0.2s;
    }

    .hero-cta:hover {
      background: var(--accent);
    }

    /* ─── SECTION SHARED ──────────────────────────────────── */
    section {
      padding: 5rem 2.5rem;
      max-width: 820px;
      margin: 0 auto;
      border-top: 1px solid var(--rule);
    }

    .section-label {
      font-size: 0.75rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
      font-weight: 500;
      margin-bottom: 2.5rem;
    }

    /* ─── ABOUT ───────────────────────────────────────────── */
    .about-grid {
      display: grid;
      grid-template-columns: 1fr 1.5fr;
      gap: 3.5rem;
      align-items: start;
    }

    .about-left h2 {
      font-family: var(--display);
      font-size: 2rem;
      font-weight: 400;
      line-height: 1.2;
      margin-bottom: 0.5rem;
    }

    .about-left .about-accent {
      display: block;
      width: 2rem;
      height: 2px;
      background: var(--accent);
      margin-top: 1rem;
    }

    .about-right p {
      font-size: 0.975rem;
      line-height: 1.8;
      color: #444;
      font-weight: 300;
      margin-bottom: 1rem;
    }

    .about-right p:last-child { margin-bottom: 0; }

    .tag-list {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-top: 1.5rem;
    }

    .tag {
      font-size: 0.75rem;
      padding: 0.3rem 0.75rem;
      background: var(--card-bg);
      border: 1px solid var(--rule);
      color: var(--muted);
      letter-spacing: 0.03em;
    }

    /* ─── WORK ────────────────────────────────────────────── */
    .work-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }

    .work-card {
      background: var(--card-bg);
      padding: 2rem;
      position: relative;
      overflow: hidden;
      transition: transform 0.25s;
    }

    .work-card:hover { transform: translateY(-3px); }

    .work-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0;
      width: 3px;
      height: 0;
      background: var(--accent);
      transition: height 0.3s ease;
    }

    .work-card:hover::before { height: 100%; }

    .work-type {
      font-size: 0.7rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent);
      font-weight: 500;
      margin-bottom: 0.75rem;
    }

    .work-card h3 {
      font-family: var(--display);
      font-size: 1.25rem;
      font-weight: 500;
      margin-bottom: 0.75rem;
    }

    .work-card p {
      font-size: 0.875rem;
      color: #666;
      line-height: 1.65;
      font-weight: 300;
    }

    .work-card-wide {
      grid-column: span 2;
    }

    /* ─── CONTACT ─────────────────────────────────────────── */
    .contact-inner {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: 2rem;
    }

    .contact-left h2 {
      font-family: var(--display);
      font-size: 2.2rem;
      font-weight: 400;
      margin-bottom: 0.75rem;
      max-width: 320px;
      line-height: 1.15;
    }

    .contact-left p {
      font-size: 0.9rem;
      color: var(--muted);
      font-weight: 300;
    }

    .contact-right {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      align-items: flex-end;
    }

    .contact-link {
      font-size: 0.85rem;
      font-weight: 400;
      color: var(--text);
      text-decoration: none;
      letter-spacing: 0.04em;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      transition: color 0.2s;
    }

    .contact-link:hover { color: var(--accent); }

    .contact-link .arrow {
      font-size: 0.8rem;
      transition: transform 0.2s;
    }

    .contact-link:hover .arrow { transform: translateX(3px); }

    /* ─── FOOTER ──────────────────────────────────────────── */
    footer {
      border-top: 1px solid var(--rule);
      padding: 1.8rem 2.5rem;
      max-width: 820px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    footer p {
      font-size: 0.78rem;
      color: var(--muted);
      font-weight: 300;
    }

    /* ─── RESPONSIVE ──────────────────────────────────────── */
    @media (max-width: 640px) {
      nav { padding: 1rem 1.5rem; }
      .hero, section, footer { padding-left: 1.5rem; padding-right: 1.5rem; }
      .about-grid { grid-template-columns: 1fr; gap: 2rem; }
      .work-grid { grid-template-columns: 1fr; }
      .work-card-wide { grid-column: span 1; }
      .contact-inner { flex-direction: column; align-items: flex-start; }
      .contact-right { align-items: flex-start; }
    }

    /* ─── SCROLL FADE-IN ──────────────────────────────────── */
    .fade-in {
      opacity: 0;
      transform: translateY(18px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .fade-in.visible {
      opacity: 1;
      transform: none;
    }

    @media (prefers-reduced-motion: reduce) {
      .fade-in { opacity: 1; transform: none; transition: none; }
    }
  </style>
</head>

<body>

  <!-- NAV -->
  <nav>
    <a class="nav-name" href="#">Ajay</a>
    <ul class="nav-links">
      <li><a href="#about">About</a></li>
      <li><a href="#work">Work</a></li>
      <li><a href="#contact">Contact</a></li>
    </ul>
  </nav>

  <!-- HERO -->
  <div class="hero">
    <p class="hero-eyebrow">Based in Malaysia</p>
    <h1 class="hero-name">Ajay.</h1>
    <p class="hero-identity">
      Student, <span class="cycling-word" id="cycler">novelist</span>, builder.
    </p>
    <p class="hero-desc">
      I study the world through equations and express it through stories.
      Currently at university, working on a novel, and building things that matter.
    </p>
    <a href="#work" class="hero-cta">See my work</a>
  </div>

  <!-- ABOUT -->
  <section id="about">
    <p class="section-label">About</p>
    <div class="about-grid fade-in">
      <div class="about-left">
        <h2>Who I am</h2>
        <span class="about-accent"></span>
      </div>
      <div class="about-right">
        <p>
          I'm a university student with a dual life: by day I work through calculus,
          electrostatics, and the clean logic of physics. By night I build underground worlds
          for characters who don't yet know what's being done to them.
        </p>
        <p>
          I believe the most interesting questions live at the boundary between
          disciplines — where a story needs to be structurally sound and a proof needs to
          feel inevitable.
        </p>
        <div class="tag-list">
          <span class="tag">Mathematics</span>
          <span class="tag">Physics</span>
          <span class="tag">Creative Writing</span>
          <span class="tag">Worldbuilding</span>
          <span class="tag">Literature</span>
        </div>
      </div>
    </div>
  </section>

  <!-- WORK -->
  <section id="work">
    <p class="section-label">Work</p>
    <div class="work-grid">

      <div class="work-card work-card-wide fade-in">
        <p class="work-type">Novel — In Progress</p>
        <h3>The Mantling</h3>
        <p>
          A post-apocalyptic literary novel set in an underground civilization where children
          are unknowingly enrolled in a research program disguised as an elite school. Exploring
          institutional power, emotional resonance, and the cost of knowing too late.
          Draws on <em>Never Let Me Go</em>, <em>Your Lie in April</em>, and the Hunger Games.
        </p>
      </div>

      <div class="work-card fade-in">
        <p class="work-type">Study Resource</p>
        <h3>PHY 102 Notes</h3>
        <p>
          Handwritten electrostatics notes converted into structured, MathJax-rendered
          HTML study guides — built for clarity and long-term review.
        </p>
      </div>

      <div class="work-card fade-in">
        <p class="work-type">Academic</p>
        <h3>MTH 102 Work</h3>
        <p>
          Exploring limits, function composition, and inverse functions through the
          Feynman Technique — teaching to understand, not just to pass.
        </p>
      </div>

    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact">
    <p class="section-label">Contact</p>
    <div class="contact-inner fade-in">
      <div class="contact-left">
        <h2>Let's talk about something real.</h2>
        <p>Open to collaboration, conversation, or feedback on the novel.</p>
      </div>
      <div class="contact-right">
        <a href="mailto:ajay@email.com" class="contact-link">
          ajay@email.com <span class="arrow">→</span>
        </a>
        <a href="#" class="contact-link">
          LinkedIn <span class="arrow">→</span>
        </a>
        <a href="#" class="contact-link">
          GitHub <span class="arrow">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer>
    <p>© 2026 Ajay. All rights reserved.</p>
    <p>Designed with intention.</p>
  </footer>

  <script>
    // ── Cycling identity words ──────────────────────────────
    const words = ['novelist', 'physicist', 'worldbuilder', 'student'];
    let i = 0;
    const el = document.getElementById('cycler');

    setInterval(() => {
      el.style.opacity = '0';
      el.style.transform = 'translateY(6px)';
      el.style.transition = 'opacity 0.3s, transform 0.3s';
      setTimeout(() => {
        i = (i + 1) % words.length;
        el.textContent = words[i];
        el.style.opacity = '1';
        el.style.transform = 'none';
      }, 320);
    }, 2400);

    // ── Scroll fade-in ──────────────────────────────────────
    const obs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          obs.unobserve(e.target);
        }
      });
    }, { threshold: 0.12 });

    document.querySelectorAll('.fade-in').forEach(el => obs.observe(el));
  </script>

</body>
</html>
